// 测试程序：计算斐波那契数列第 5 项
// 预期结果：fib(5) = 5

// 主函数
function Main.main 1
push constant 5
call Fibonacci.fib 1
pop local 0
push local 0
return

// Fibonacci.fib 函数
function Fibonacci.fib 0
push argument 0
push constant 2
lt
if-goto IF_TRUE0
goto IF_FALSE0

label IF_TRUE0
push constant 1
return

label IF_FALSE0
push argument 0
push constant 1
sub
call Fibonacci.fib 1
push argument 0
push constant 2
sub
call Fibonacci.fib 1
add
return
